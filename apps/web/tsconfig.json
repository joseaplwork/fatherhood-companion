{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "incremental": true,
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@web/*": ["./*"],
      "@/grove-companion/domain": ["../../packages/domain/src/index.ts"],
      "@/grove-companion/domain/*": ["../../packages/domain/src/*"],
      "@/grove-companion/db": ["../../packages/db/src/index.ts"],
      "@/grove-companion/ai": ["../../packages/ai/src/index.ts"],
      "@/grove-companion/ai/*": ["../../packages/ai/src/*"],
      "@/grove-companion/ui": ["../../packages/ui/src/index.ts"],
      "@/grove-companion/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
