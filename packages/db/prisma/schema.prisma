generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum OnboardingState {
  PENDING
  COMPLETE
}

enum SubscriptionTier {
  FREE
  PREMIUM
}

enum ReactionType {
  HEART
  SUPPORT
  HELPFUL
}

enum RsvpStatus {
  GOING
  MAYBE
  NOT_GOING
}

enum EventKind {
  IN_PERSON
  VIRTUAL
}

enum CalendarEntryType {
  PERSONAL
  CHILD_CARE
  CUSTODY
  MEDICAL
  SCHOOL
  COMMUNITY_EVENT
  REMINDER
}

enum ResourceCategory {
  MENTAL_HEALTH
  CO_PARENTING
  LEGAL
  FINANCE
  CHILD_DEVELOPMENT
  SELF_CARE
  COMMUNITY
}

enum ResourceType {
  ARTICLE
  VIDEO
  EXERCISE
  MINI_COURSE
  GUIDE
}

enum NotificationType {
  EVENT_REMINDER
  COMMUNITY_REPLY
  AI_CHECKIN
  MOOD_REMINDER
  NEW_RESOURCE
}

enum MessageRole {
  USER
  ASSISTANT
}

enum CoParentContactPreference {
  UNSPECIFIED
  APP
  TEXT
  EMAIL
  PHONE
  LEGAL_ONLY
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model UserProfile {
  id               String           @id @default(cuid())
  providerUserId   String           @unique
  bio              String?
  location         String?
  interests        String[]
  fcmToken         String?
  onboardingState  OnboardingState  @default(PENDING)
  subscriptionTier SubscriptionTier @default(FREE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  moodEntries          MoodEntry[]
  conversations        AIConversation[]
  communityPosts       CommunityPost[]
  postReplies          PostReply[]
  postReactions        PostReaction[]
  hostedEvents         CommunityEvent[]
  eventRsvps           EventRsvp[]
  calendarEntries      CalendarEntry[]
  resourceInteractions ResourceInteraction[]
  notifications        Notification[]
  coParents            CoParent[]
}

model MoodEntry {
  id        String      @id @default(cuid())
  userId    String
  profile   UserProfile @relation(fields: [userId], references: [id])
  mood      Int
  note      String?
  emotions  String[]
  imageUrl  String?
  date      DateTime    @db.Date
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

model AIConversation {
  id         String      @id @default(cuid())
  userId     String
  profile    UserProfile @relation(fields: [userId], references: [id])
  title      String?
  summary    String?
  moodContext Int?
  tokensUsed Int         @default(0)
  archivedAt DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  messages ConversationMessage[]

  @@index([userId, createdAt])
}

model ConversationMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String
  tokensUsed     Int            @default(0)
  createdAt      DateTime       @default(now())

  @@index([conversationId, createdAt])
}

model CommunityPost {
  id            String      @id @default(cuid())
  userId        String
  profile       UserProfile @relation(fields: [userId], references: [id])
  title         String
  content       String
  isPinned      Boolean     @default(false)
  isLocked      Boolean     @default(false)
  replyCount    Int         @default(0)
  reactionCount Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  replies   PostReply[]
  reactions PostReaction[]

  @@index([createdAt])
  @@index([userId])
}

model PostReply {
  id        String        @id @default(cuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  profile   UserProfile   @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([postId, createdAt])
}

model PostReaction {
  id        String        @id @default(cuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  profile   UserProfile   @relation(fields: [userId], references: [id])
  type      ReactionType
  createdAt DateTime      @default(now())

  @@unique([postId, userId, type])
  @@index([postId])
}

model CommunityEvent {
  id          String      @id @default(cuid())
  userId      String
  profile     UserProfile @relation(fields: [userId], references: [id])
  title       String
  description String
  kind        EventKind
  location    String?
  onlineUrl   String?
  capacity    Int?
  startAt     DateTime
  endAt       DateTime
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  rsvps           EventRsvp[]
  calendarEntries CalendarEntry[]

  @@index([startAt])
}

model EventRsvp {
  id        String         @id @default(cuid())
  eventId   String
  event     CommunityEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  profile   UserProfile    @relation(fields: [userId], references: [id])
  status    RsvpStatus
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([eventId, userId])
  @@index([userId])
}

model CalendarEntry {
  id               String            @id @default(cuid())
  userId           String
  profile          UserProfile       @relation(fields: [userId], references: [id])
  title            String
  description      String?
  type             CalendarEntryType
  startAt          DateTime
  endAt            DateTime?
  allDay           Boolean           @default(false)
  color            String?
  childRef         String?
  communityEventId String?
  communityEvent   CommunityEvent?   @relation(fields: [communityEventId], references: [id])
  recurrenceRule   String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([userId, startAt])
}

model Resource {
  id           String           @id @default(cuid())
  slug         String           @unique
  title        String
  description  String
  type         ResourceType
  category     ResourceCategory
  contentUrl   String?
  thumbnailUrl String?
  isAiEnhanced Boolean          @default(false)
  isPublished  Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  interactions ResourceInteraction[]

  @@index([category, isPublished])
}

model ResourceInteraction {
  id         String      @id @default(cuid())
  resourceId String
  resource   Resource    @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  userId     String
  profile    UserProfile @relation(fields: [userId], references: [id])
  saved      Boolean     @default(false)
  completed  Boolean     @default(false)
  rating     Int?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([resourceId, userId])
  @@index([userId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  profile   UserProfile      @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  body      String
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime         @default(now())

  @@index([userId, readAt, createdAt])
}

/// Private metadata about the other co-parent. Visible only to the owning user.
model CoParent {
  id                 String                    @id @default(cuid())
  userId             String                    @unique
  profile            UserProfile               @relation(fields: [userId], references: [id])
  name               String
  contactPreference  CoParentContactPreference @default(UNSPECIFIED)
  communicationNotes String?
  custodyArrangement String?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
}
